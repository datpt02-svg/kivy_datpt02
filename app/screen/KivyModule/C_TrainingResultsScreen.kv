#:import DefaultValuesC3 app.libs.constants.default_values.DefaultValuesC3

<C3SettingsSection>:
    orientation: 'vertical'
    size_hint_y: None
    height: self.minimum_height

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        spacing: dp(30)

        FormLabelInput:
            label_key: 'blur_result_label_C3'
            required: True

            FormGroup:
                spacing: dp(15)
                orientation: 'vertical'
                FormSlider:
                    id: c3_blur_input
                    size_hint_x: 1
                    input_filter: 'int'
                    validation_type: 'int_odd'
                    step: DefaultValuesC3.C3_BLUR_INPUT_STEP
                    min_value: DefaultValuesC3.C3_BLUR_INPUT_MIN_VALUE
                    max_value: DefaultValuesC3.C3_BLUR_INPUT_MAX_VALUE
                    allow_none: not DefaultValuesC3.C3_BLUR_INPUT_REQUIRED
                    strict: False
                ErrorMessage:
                    text: app.lang.get(c3_blur_input.ids.input_box.error_message).format(min_val=c3_blur_input.min_value, max_val=c3_blur_input.max_value) if c3_blur_input.ids.input_box.error_message else ''

        FormLabelInput:
            label_key: 'min_area_label_C3'
            required: True

            FormGroup:
                spacing: dp(15)
                orientation: 'vertical'
                FormSlider:
                    id: c3_min_area_input
                    size_hint_x: 1
                    input_filter: 'int'
                    validation_type: 'int'
                    min_value: DefaultValuesC3.C3_MIN_AREA_INPUT_MIN_VALUE
                    max_value: DefaultValuesC3.C3_MIN_AREA_INPUT_MAX_VALUE
                    allow_none: not DefaultValuesC3.C3_MIN_AREA_INPUT_REQUIRED
                    strict: False
                ErrorMessage:
                    text: app.lang.get(c3_min_area_input.error_message).format(min_val=c3_min_area_input.min_value, max_val=c3_min_area_input.max_value) if c3_min_area_input.error_message else ''

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        spacing: dp(30)

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None

            FormLabel:
                markup: True
                text: app.lang.get('threshold_label_C3', required=True)
                pos_hint: {'center_y': 0.5}
                size_hint_x: 1
                halign: 'left'
                valign: 'middle'
                padding: [0, dp(5), 0, 0]

            FormGroup:
                spacing: dp(15)
                orientation: 'vertical'
                FormSlider:
                    id: c3_threshold_slider
                    size_hint_x: 1
                    input_filter: 'int'
                    validation_type: 'int'
                    min_value: DefaultValuesC3.C3_THRESHOLD_INPUT_MIN_VALUE
                    max_value: DefaultValuesC3.C3_THRESHOLD_INPUT_MAX_VALUE
                    allow_none: not DefaultValuesC3.C3_THRESHOLD_INPUT_REQUIRED
                    show_color_palette: DefaultValuesC3.C3_THRESHOLD_INPUT_SHOW_COLOR
                    strict: False
                ErrorMessage:
                    text: app.lang.get(c3_threshold_slider.ids.input_box.error_message).format(min_val=c3_threshold_slider.min_value, max_val=c3_threshold_slider.max_value) if c3_threshold_slider.ids.input_box.error_message else ''

        FormLabelInput:
            label_key: 'event_intensity_label_C3'
            required: True
            size_hint_x: 1

            FormGroup:
                spacing: dp(15)
                orientation: 'vertical'
                FormSlider:
                    id: c3_event_intensity
                    size_hint_x: 1
                    input_filter: 'int'
                    validation_type: 'int'
                    min_value: DefaultValuesC3.C3_EVENT_INTENSITY_INPUT_MIN_VALUE
                    max_value: DefaultValuesC3.C3_EVENT_INTENSITY_INPUT_MAX_VALUE
                    allow_none: not DefaultValuesC3.C3_EVENT_INTENSITY_INPUT_REQUIRED
                    strict: False
                ErrorMessage:
                    text: app.lang.get(c3_event_intensity.error_message).format(min_val=c3_event_intensity.min_value, max_val=c3_event_intensity.max_value) if c3_event_intensity.error_message else ''

<C3PreviewOptionsSection>:
    orientation: 'vertical'
    padding: [dp(24), dp(24), dp(24), dp(240)]
    spacing: dp(10)

    FormLabel:
        text_key: "option_title_preview_c3"
        color: COLORS['BLUE_BLACK']
        halign: 'center'
        valign: 'middle'
        size_hint_x: 1
        size_hint_y: None
        height: dp(30)
        font_size: dp(16.5)
        bold: True
        padding: [0, 0, 0, 0]
        text_size: self.size

    # Separator Line
    BoxLayout:
        size_hint_y: None
        height: dp(2)
        padding: [0, 0, 0, 0]
        Widget:
            size_hint_y: None
            height: dp(1)
            canvas:
                Color:
                    rgba: COLORS['LIGHT_BLUE_GRAY']
                Rectangle:
                    pos: self.pos
                    size: self.size

    # Spacer
    Widget:
        size_hint_y: None
        height: dp(5)

    # Checkboxes
    FormCheckBox:
        id: chk_bbox
        text: app.lang.get("show_bbox_c3")
        active: True
        size_hint_y: None
        height: dp(35)
        spacing: dp(12)

    FormCheckBox:
        id: chk_info
        text: app.lang.get("show_info_c3")
        active: True
        size_hint_y: None
        height: dp(35)
        spacing: dp(12)

    # Spacer
    Widget:
        size_hint_y: None
        height: dp(5)

    # Labels for slider
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: dp(30)
        FormLabel:
            text_key: "transparent_c3"
            color: COLORS['MEDIUM_GRAY']
            halign: 'left'
            valign: 'center'
            size_hint_x: 0.7
            font_size: dp(14.4)
            text_size: self.size
        Label:
            id: slider_value_label
            text: "{:.2f}".format(transparency_slider.value)
            color: COLORS['DARK_RED']
            halign: 'right'
            valign: 'center'
            size_hint_x: 0.3
            font_size: dp(14.4)
            bold: True
            text_size: self.size

    # Slider
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(4)
        size_hint_y: None
        height: dp(30)
        Slider:
            id: transparency_slider
            min: DefaultValuesC3.C3_TRANSPARENCY_SLIDER_MIN_VALUE
            max: DefaultValuesC3.C3_TRANSPARENCY_SLIDER_MAX_VALUE
            value: DefaultValuesC3.C3_TRANSPARENCY_SLIDER_INPUT
            step: DefaultValuesC3.C3_TRANSPARENCY_SLIDER_STEP
            size_hint_y: None
            height: dp(30)
            padding: dp(8)
            value_track: True
            value_track_color: COLORS['SKY_BLUE']
            value_track_width: dp(4)
            cursor_size: dp(16), dp(16)
            background_width: dp(3)
            background_color: COLORS['TRANSPARENT']
            canvas.before:
                Color:
                    rgba: COLORS['DOVE_WHITE']
                RoundedRectangle:
                    radius: [dp(3)]
                    pos: self.x + self.padding, self.center_y - self.background_width / 2
                    size: self.width - self.padding * 2, self.background_width * 2


<ValidationItem>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(210)
    padding: [dp(8), dp(8), dp(8), dp(5)]
    spacing: dp(5)
    canvas.before:
        Color:
            rgba: 0.741, 0.765, 0.78, 1
        Line:
            rectangle: self.x + 0.5, self.y + 0.5, self.width - 1, self.height - 1
            width: dp(1)
    
    FloatLayout:
        size_hint_y: None
        height: dp(200)
        pos_hint: {'top': 1}
        canvas.before:
            Color:
                rgba: COLORS['DOVE_WHITE']
            Rectangle:
                pos: self.x, self.y
                size: self.width, self.height
        Image:
            id: img_widget
            source: root.source
            fit_mode: 'contain'
            nocache: True
            mipmap: False
            size_hint: 1, 1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

        FloatLayout:
            size_hint: None, None
            size: dp(85), dp(40)
            pos_hint: {'right': 1, 'top': 1}
            opacity: 1 if root.get_label_from_source() else 0
            FormButton:
                size_hint: None, None
                pos_hint: {'right': 0.9, 'top': 0.8}
                on_size: self.size = dp(85), dp(40)
                font_size: dp(11)
                bg_color: COLORS['YELLOW']
                text_color: COLORS['BLACK']
                text: root.get_label_from_source() or ""
                enable_hover: False

<FormLabelInput@BoxLayout>:
    orientation: 'vertical'
    size_hint_y: None
    size_hint_x: 0.5
    spacing: dp(25)
    padding: [0, dp(10), 0, 0]

    label_key: ''
    required: False
    FormLabel:
        markup: True
        text: app.lang.get(root.label_key, required=root.required) if root.required else app.lang.get(root.label_key)
        size_hint_x: 1
        pos_hint: {'center_y': 0.5}
        halign: 'left'
        valign: 'middle'
        padding: [0, dp(20), 0, 0]

<TrainingResultsScreen>:
    name: 'screen_C3_training_results'
    ScrollView:
        id: scroll_screen_C3_training_results
        bar_width: dp(10)
        scroll_type: ['bars']
        effect_cls: "ScrollEffect" # Basic scroll effect
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(30)
            spacing: dp(25)

            PageHeader: # Page Title (H2)
                text: app.lang.get('training_results_title_C3')

            FormLabel:
                markup: True
                text: app.lang.get('trained_model_label_C3', required=True)
                size_hint_x: 1
                pos_hint: {'center_y': 0.5}
                halign: 'left'
                valign: 'middle'
                padding: [0, dp(10), 0, 0]

            FormGroup:
                spacing: dp(15)
                orientation: 'vertical'
                FormSpinner:
                    id: c3_dataset_select
                    text: DefaultValuesC3.C3_DATASET_SELECT
                    size_hint_x: 1
                    hint_text: app.lang.get('select_dataset_results_placeholder_C3')
                    on_text: root.on_dataset_selection_changed()
                    allow_none: not DefaultValuesC3.C3_DATASET_SELECT_REQUIRED
                    validation_type: 'string'
                ErrorMessage:
                    text: app.lang.get(c3_dataset_select.error_message)


            BoxLayout:
                size_hint_y: None
                orientation: 'horizontal'
                height: dp(35)
                spacing: dp(15)
                FormButton:
                    id: create_heatmap_button_c3
                    text: app.lang.get('create_heatmap_c3')
                    on_release: root.create_heatmap()
                    bg_color: COLORS['BLUE']

                ErrorMessage:
                    id: create_heatmap_error
                    text: app.lang.get(self.error_message)
                    padding: [0, 0, 0, dp(20)]


            SeparatorDash:
                dashed: True
                dash_width: dp(3)
                dash_spacing: dp(2)


            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                spacing: dp(0)
                height: self.minimum_height

                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(5)
                    Label:
                        size_hint_y: None
                        pos_hint: {'top': 1}
                        font_size: dp(17.6)
                        color: COLORS['BLUE_BLACK']
                        text_size: self.width, None
                        height: self.texture_size[1] + dp(10)
                        bold: True
                        text: app.lang.get('confirmation_parameters_label_C3')

                    SeparatorDash:
                        dashed: True
                        dash_width: dp(2)       # dash_length
                        dash_spacing: dp(1)

                C3SettingsSection:
                    id: c3_settings_section

            BoxLayout:
                size_hint_y: None
                height: dp(40)
                spacing: dp(20)
                FormButton:
                    id: validate_button_c3
                    text: app.lang.get('validate_button_C3')
                    on_release: root.start_validation()
                    bg_color: COLORS['BLUE']

                FormButton:
                    id: save_button_c3
                    text: app.lang.get('save_button_C3')
                    on_release: root.save_parameters()

                FormButton:
                    id: reload_preset_button_c3
                    text: app.lang.get('reload_preset_button_c3')
                    on_release: root.reload_preset()

            Separator:

            FormGroup:
                orientation: 'horizontal'
                padding: [0, dp(-10), 0, 0]
                Label:
                    size_hint_y: None
                    pos_hint: {'top': 1}
                    font_size: dp(17.6)
                    color: COLORS['BLUE_BLACK']
                    text_size: self.width, None
                    height: self.texture_size[1] + dp(10)
                    bold: True
                    text: app.lang.get('validation_results_title_C3')

                FormButton:
                    text: app.lang.get('reload_button')
                    on_release: root.reload_validation_album()

                FormButton:
                    id: window_explore_button
                    text: app.lang.get('open_folder_button')
                    on_release: root.open_folder()
                    bg_color: COLORS['BLUE']

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [0, dp(-15), 0, 0]
                InfoBoxSimple:
                    id: folder_displaying

            BoxLayout:
                id: image_album_container
                orientation: 'vertical'
                size_hint_y: None
                height: dp(560)
                padding: dp(10)
                canvas.before:
                    Color:
                        rgba: COLORS['VERY_LIGHT_GRAY']
                    Line:
                        rounded_rectangle: (self.x + 0.5, self.y + 0.5, self.width - 1, self.height - 1, dp(4))
                        width: dp(1)